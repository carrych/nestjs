# ─── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────
# NOTE: DB_HOST=localhost is for local dev without Docker.
# In Docker, compose.yml overrides DB_HOST=postgres automatically.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=nestjs-db

# ─── Auth ────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=15m

# ─── Security / CORS ─────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Dev default: http://localhost:3000,http://localhost:5173
# Production: set to exact frontend domain(s), never use '*'
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting (Throttler) ───────────────────────────────────
# Global policy: max requests per TTL window (per IP)
THROTTLE_GLOBAL_TTL=60000
THROTTLE_GLOBAL_LIMIT=100
# Strict policy: for auth / payment / admin endpoints
THROTTLE_STRICT_TTL=60000
THROTTLE_STRICT_LIMIT=5

# ─── AWS S3 ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-central-1
AWS_S3_BUCKET=your-bucket-name
# For LocalStack (dev only):
# AWS_S3_ENDPOINT=http://localhost:4566
# AWS_S3_FORCE_PATH_STYLE=true

# ─── RabbitMQ ────────────────────────────────────────────────────
# In Docker, compose.yml overrides RABBITMQ_URL automatically via compose.dev.yml.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_PREFETCH=10
WORKERS_ENABLED=true

# ─── Payments gRPC ───────────────────────────────────────────────
# payments-service gRPC server address (host:port)
PAYMENTS_GRPC_URL=localhost:50051
# gRPC server listen port (used by payments-service entrypoint)
PAYMENTS_GRPC_PORT=50051
# Client-side deadline for Payments.Authorize calls (milliseconds)
PAYMENTS_GRPC_TIMEOUT_MS=5000

# ─── Nova Poshta ─────────────────────────────────────────────────
NP_API_KEY=your_nova_poshta_api_key

# ─── UkrPoshta ───────────────────────────────────────────────────
UKRPOSHTA_TOKEN=your_ukrposhta_token
UKRPOSHTA_ECOM=your_ukrposhta_ecom_bearer
UKRPOSHTA_SENDER_POSTCODE=01001
UKRPOSHTA_SENDER_FIRST_NAME=Shop
UKRPOSHTA_SENDER_LAST_NAME=Name
UKRPOSHTA_SENDER_PHONE=380000000000
