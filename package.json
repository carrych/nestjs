{
  "name": "nestjs",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@4.6.0",
  "scripts": {
    "build": "nest build",
    "start:fresh": "yarn migration:run && yarn seed && yarn build && yarn start",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "dotenv -e .env.test -- node dist/src/main.js",
    "start:dev": "dotenv -e .env.test -- nest start --watch",
    "start:debug": "dotenv -e .env.test -- nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "start:payments-grpc": "ts-node -r tsconfig-paths/register src/payments-grpc/main.ts",
    "start:payments-grpc:prod": "node dist/src/payments-grpc/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "db:drop": "yarn typeorm schema:drop",
    "db:reset": "yarn db:drop && yarn migration:run && yarn seed",
    "pretest": "yarn migration:run && yarn seed",
    "test": "jest",
    "test:unit": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "localstack:ensure": "bash scripts/ensure-localstack.sh",
    "test:e2e": "yarn localstack:ensure && yarn db:reset && jest --config ./test/jest-e2e.json; yarn db:drop",
    "typeorm": "dotenv -e .env.test -- ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d data-source.ts",
    "migration:run": "yarn typeorm migration:run",
    "migration:revert": "yarn typeorm migration:revert",
    "migration:generate": "yarn typeorm migration:generate",
    "seed": "dotenv -e .env.test -- ts-node -r tsconfig-paths/register src/seed/seed.ts",
    "dev:start": "./scripts/dev-start.sh",
    "test:docker": "./scripts/test-docker.sh"
  },
  "dependencies": {
    "@apollo/server": "~5.4.0",
    "@as-integrations/express5": "~1.1.2",
    "@aws-sdk/client-s3": "~3.995.0",
    "@aws-sdk/s3-request-presigner": "~3.995.0",
    "@grpc/grpc-js": "~1.14.3",
    "@grpc/proto-loader": "~0.8.0",
    "@nestjs/apollo": "~13.2.4",
    "@nestjs/common": "~11.0.1",
    "@nestjs/config": "~4.0.2",
    "@nestjs/core": "~11.0.1",
    "@nestjs/graphql": "~13.2.4",
    "@nestjs/jwt": "~11.0.2",
    "@nestjs/mapped-types": "~2.1.0",
    "@nestjs/microservices": "~11.0.1",
    "@nestjs/passport": "~11.0.5",
    "@nestjs/platform-express": "~11.0.1",
    "@nestjs/platform-socket.io": "~11.1.19",
    "@nestjs/schedule": "~6.1.1",
    "@nestjs/throttler": "~6.5.0",
    "@nestjs/typeorm": "~11.0.0",
    "@nestjs/websockets": "~11.1.19",
    "amqp-connection-manager": "~5.0.0",
    "amqplib": "~0.10.9",
    "bcrypt": "~6.0.0",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.14.3",
    "dataloader": "~2.2.3",
    "graphql": "~16.12.0",
    "helmet": "~8.1.0",
    "passport": "~0.7.0",
    "passport-jwt": "~4.0.1",
    "pg": "~8.18.0",
    "reflect-metadata": "~0.2.2",
    "rxjs": "~7.8.1",
    "socket.io": "~4.8.3",
    "typeorm": "~0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "~3.2.0",
    "@eslint/js": "~9.18.0",
    "@nestjs/cli": "~11.0.0",
    "@nestjs/schematics": "~11.0.0",
    "@nestjs/testing": "~11.0.1",
    "@types/amqplib": "~0.10.8",
    "@types/bcrypt": "~6.0.0",
    "@types/express": "~5.0.0",
    "@types/jest": "~30.0.0",
    "@types/node": "~22.10.7",
    "@types/passport-jwt": "~4.0.1",
    "@types/pg": "~8",
    "@types/supertest": "~6.0.2",
    "aws-sdk-client-mock": "~4.1.0",
    "dotenv-cli": "~11.0.0",
    "eslint": "~9.18.0",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-prettier": "~5.2.2",
    "globals": "~16.0.0",
    "jest": "~30.0.0",
    "prettier": "~3.4.2",
    "source-map-support": "~0.5.21",
    "supertest": "~7.0.0",
    "ts-jest": "~29.2.5",
    "ts-loader": "~9.5.2",
    "ts-node": "~10.9.2",
    "tsconfig-paths": "~4.2.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "~8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
